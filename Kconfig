mainmenu "WallaBMC"

config APP_DNS_RESOLVE
	bool
	select REQUIRES_FULL_LIBC
	select NET_SOCKETS_SERVICE
	select DNS_RESOLVER
	select NET_DHCPV4_OPTION_DNS_ADDRESS
	# If DHCP is not enabled, then need these. For now, DNS/NTP
	# requires DHCP. Could make DNS configurable.
	select DNS_SERVER_IP_ADDRESSES
	select DNS_RECONFIGURE_CLEANUP

config DNS_SERVER1
	string
	default "1.1.1.1" if APP_DNS_RESOLVE

config APP_NTP
	bool "NTP time synchronisation"
	select SNTP
	select APP_DNS_RESOLVE
	# Could these options reduce our code?
	#CONFIG_NET_CONFIG_CLOCK_SNTP_INIT=y
	#CONFIG_NET_CONFIG_CLOCK_SNTP_SET_RTC=y
	default y

config MAIN_STACK_SIZE
	int
	default 4096 if PERSISTENT_STORAGE

config APP_CRYPTO
	bool
	select MBEDTLS
	select MBEDTLS_ENABLE_HEAP
	select NET_SOCKETS_SOCKOPT_TLS
	select TLS_CREDENTIALS
	select PSA_WANT_ALG_ECDH
	select PSA_WANT_ALG_ECDSA
	select PSA_WANT_ECC_SECP_R1_256
	select PSA_WANT_ECC_SECP_R1_384
	select PSA_WANT_KEY_TYPE_ECC_PUBLIC_KEY
	select PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_IMPORT
	select PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_EXPORT
	select PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_GENERATE
	select MBEDTLS_KEY_EXCHANGE_ECDHE_ECDSA_ENABLED
	select PSA_WANT_ALG_CCM
	select PSA_WANT_ALG_GCM
	select MBEDTLS_PK_WRITE_C
	select PSA_WANT_ALG_TLS12_PRF
	select PSA_WANT_ALG_SHA_1
	select PSA_WANT_ALG_SHA_256
	select PSA_WANT_ALG_SHA_384
	select PSA_CRYPTO
	select PSA_WANT_ALG_CHACHA20_POLY1305
	select PSA_WANT_KEY_TYPE_CHACHA20
# TLS1.3
	select MBEDTLS_SSL_PROTO_TLS1_3
	select MBEDTLS_SSL_TLS1_3_KEY_EXCHANGE_MODE_EPHEMERAL_ENABLED
	select PSA_CRYPTO_ENABLE_ALL
	select PSA_WANT_ALG_HKDF
	select PSA_WANT_ALG_HKDF_EXTRACT
	select PSA_WANT_ALG_HKDF_EXPAND
	select MBEDTLS_USE_PSA_CRYPTO
	select MBEDTLS_PSA_CRYPTO_C
	select MBEDTLS_ECP_C
	select MBEDTLS_ECDH_C
	select MBEDTLS_ECDSA_C
	select MBEDTLS_HMAC_DRBG_C
	select MBEDTLS_CTR_DRBG_C
	select MBEDTLS_HKDF_C
	select MBEDTLS_MAC_SHA256_ENABLED
	select MBEDTLS_MAC_SHA384_ENABLED
	select MBEDTLS_CIPHER_CCM_ENABLED
	select MBEDTLS_CIPHER_GCM_ENABLED
	select MBEDTLS_CHACHA20_ENABLED
	select MBEDTLS_POLY1305_ENABLED
	select MBEDTLS_CHACHA20_POLY1305_ENABLED
	select MBEDTLS_ECP_DP_SECP256R1_ENABLED
	select MBEDTLS_ECDSA_DETERMINISTIC
	select MBEDTLS_SSL_ALPN

config APP_CRYPTO_DEBUG
	bool
	default n
	select MBEDTLS_DEBUG
	select MBEDTLS_MEMORY_DEBUG

config MBEDTLS_DEBUG_LEVEL
	int
	depends on APP_CRYPTO_DEBUG
	default 1

config MBEDTLS_HEAP_SIZE
	int
	depends on APP_CRYPTO
	default 49152

config NET_PKT_RX_COUNT
	int
	depends on APP_CRYPTO
	default 32

config NET_PKT_TX_COUNT
	int
	depends on APP_CRYPTO
	default 32

config NET_BUF_RX_COUNT
	int
	default 64 if APP_CRYPTO
	default 48

config NET_BUF_TX_COUNT
	int
	default 64 if APP_CRYPTO
	default 48

config NET_SOCKETS_TLS_MAX_CONTEXTS
	int
	depends on APP_CRYPTO
	default 6

# The Kconfig comments for this option say TLS standards require
# 16k size, but this requires several 16K allocations each for
# send and recv on the heap so it's too large. Apparently browsers
# negotiate smaller sizes, so 1500 should be okay there. Redfish
# and curl with auth headers seem to require more (4096 works).
# may require more?
config MBEDTLS_SSL_MAX_CONTENT_LEN
	int
	depends on APP_CRYPTO
	default 4096

config APP_HTTPS
	bool "HTTPS supprot for web and redfish"
	default y
	depends on REDFISH || APP_WEB
	select HTTP_SERVER_TLS_USE_ALPN
	select APP_CRYPTO

config REDFISH
	bool "Redfish server"
	default y
	select HTTP_SERVER
	select HTTP_SERVER_CAPTURE_HEADERS
	select JSON_LIBRARY
	select BASE64

if REDFISH

config REDFISH_SYSTEM_PRODUCT_NAME
	string "Redfish system product / board display name"
	default "WallaBMC Board"
	help
	  Shown as System Name in Redfish and in the dashboard System Overview.

config REDFISH_SYSTEM_MANUFACTURER
	string "Redfish system manufacturer"
	default "WallaBMC"

config REDFISH_SYSTEM_MODEL
	string "Redfish system model"
	default "Generic"

config REDFISH_SYSTEM_PROCESSOR_MODEL
	string "Redfish processor summary model"
	default "N/A"

config REDFISH_SYSTEM_PROCESSOR_COUNT
	int "Redfish processor summary count"
	default 1

config REDFISH_SYSTEM_MEMORY_GIB
	int "Redfish memory summary total (GiB)"
	default 0
	help
	  Total system memory in GiB for Redfish MemorySummary. 0 shows as N/A.

config HTTP_SERVER_MAX_HEADER_LEN
	int
	default 48 # Basic auth header + 15 character password is 34 characters

endif # REDFISH

config APP_WEB
	bool "Web server"
	default y
	select HTTP_SERVER
	select REDFISH

config APP_WEB_TERMINAL
	bool "Browser based terminal emulator"
	default y
	select APP_WEB
	select HTTP_SERVER_WEBSOCKET
	select SHELL
	select SHELL_BACKEND_WEBSOCKET
	select LOG_BACKEND_WS
	select LOG_BACKEND_WS_AUTOSTART

config DEFAULT_ADMIN_PASSWORD
	string "Default admin password"
	default "$(shell,openssl rand -base64 12 | head -c 15)"

config SYSTEM_WORKQUEUE_STACK_SIZE
	int
	depends on HTTP_SERVER_WEBSOCKET
	default 2560 if APP_HTTPS
	default 1536

# WS log backend uses lot of stack
config LOG_PROCESS_THREAD_STACK_SIZE
	int
	depends on LOG_BACKEND_WS
	default 2560

config NET_TCP_MAX_RECV_WINDOW_SIZE
	int
	default 20480

# Increase retry and timeout limits
config NET_TCP_INIT_RETRANSMISSION_TIMEOUT
	int
	default 500

config NET_TCP_RETRY_COUNT
	int
	default 10

config SHELL_STACK_SIZE
	int
	depends on SHELL_BACKEND_WEBSOCKET
	default 3072

config HTTP_SERVER_STACK_SIZE
	int
	depends on LOG_BACKEND_WS
	default 4096

config NET_SOCKETS_SERVICE_STACK_SIZE
	int
	default 3072 if APP_CRYPTO
	default 1536

config NET_MAX_CONTEXTS
	int
	depends on HTTP_SERVER
	default 12

config NET_MAX_CONN
	int
	depends on HTTP_SERVER
	default 16

config ZVFS_EVENTFD_MAX
	int
	depends on HTTP_SERVER
	default 4

config ZVFS_POLL_MAX
	int
	depends on HTTP_SERVER
	default 8

config PERSISTENT_STORAGE
	bool "Persistent storage for config"
	default n
	# Enable Flash and Flash Map to access memory
	select FLASH
	select FLASH_MAP
	# select FLASH_SHELL if SHELL # ~4kB flash
	# Writing internal flash that is used for XIP requires
	# that the flash driver is relocated into RAM.
	select CODE_DATA_RELOCATION_SRAM
	# XXX: May need to enable these, or disable IRQs in the flash
	# erase and program functions while flash is being written.
	# select SRAM_VECTOR_TABLE
	# select SRAM_SW_ISR_TABLE
	# select DEVICE_MUTABLE
	
	# Enable Filesystem and LittleFS
	select FILE_SYSTEM
	select FILE_SYSTEM_LITTLEFS
	select FILE_SYSTEM_MKFS

config JTAG
	bool "JTAG support"
	depends on $(dt_path_enabled,/jtag)
	default y

if JTAG

config JTAG_DAEMON_STACK_SIZE
	int "JTAG daemon stack size"
	default 1024

config JTAG_DAEMON_PRIORITY
	int "JTAG daemon priority"
	default 5

endif

# use `kernel thread stack` shell command
config APP_STACK_DEBUG
	bool
	default n
	select THREAD_NAME
	select THREAD_ANALYZER
	select THREAD_ANALYZER_RUN_UNLOCKED
config CONSOLE_BRIDGE
	bool "Console bridge (USART6 to TCP port 22)"
	default y
	select SERIAL
	select SERIAL_SUPPORT_ASYNC
	select UART_ASYNC_API

if CONSOLE_BRIDGE

config CONSOLE_BRIDGE_STACK_SIZE
	int "Console bridge daemon stack size"
	default 1024

config CONSOLE_BRIDGE_PRIORITY
	int "Console bridge daemon priority"
	default 5

endif

source "Kconfig.zephyr"
