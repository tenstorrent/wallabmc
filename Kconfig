mainmenu "Atlantis BMC application"

config MAIN_STACK_SIZE
	int
	default 4096 if PERSISTENT_STORAGE

config APP_CRYPTO
	bool
	select MBEDTLS
	select MBEDTLS_ENABLE_HEAP
	select NET_SOCKETS_SOCKOPT_TLS
	select TLS_CREDENTIALS
	select PSA_WANT_ALG_ECDH
	select PSA_WANT_ALG_ECDSA
	select PSA_WANT_ECC_SECP_R1_256
	select PSA_WANT_KEY_TYPE_ECC_PUBLIC_KEY
	select PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_IMPORT
	select PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_EXPORT
	select PSA_WANT_KEY_TYPE_ECC_KEY_PAIR_GENERATE
	select MBEDTLS_KEY_EXCHANGE_ECDHE_ECDSA_ENABLED
	select PSA_WANT_ALG_CCM
	select PSA_WANT_ALG_GCM
	select MBEDTLS_PK_WRITE_C
	select PSA_WANT_ALG_TLS12_PRF
	select PSA_WANT_ALG_SHA_1
	select PSA_WANT_ALG_SHA_256
	select PSA_CRYPTO
	select PSA_WANT_ALG_CHACHA20_POLY1305
	select PSA_WANT_KEY_TYPE_CHACHA20

config MBEDTLS_HEAP_SIZE
	int
	depends on APP_CRYPTO
#	Redfish authentication uses about 16500 bytes
	default 20000

config NET_SOCKETS_TLS_MAX_CONTEXTS
	int
	depends on APP_CRYPTO
	default 4

config MBEDTLS_SSL_MAX_CONTENT_LEN
	int
	depends on APP_CRYPTO
	default 2048

config APP_HTTPS
	bool "HTTPS supprot for web and redfish"
	default y
	depends on REDFISH || APP_WEB
	select APP_CRYPTO

config REDFISH
	bool "Redfish server"
	default y
	select HTTP_SERVER
	select HTTP_SERVER_CAPTURE_HEADERS
	select JSON_LIBRARY
	select BASE64

config APP_WEB
	bool "Web server"
	default y
	select HTTP_SERVER
	select REDFISH

config NET_MAX_CONTEXTS
	int
	depends on HTTP_SERVER
	default 12

config NET_MAX_CONN
	int
	depends on HTTP_SERVER
	default 16

config ZVFS_EVENTFD_MAX
	int
	depends on HTTP_SERVER
	default 4

config ZVFS_POLL_MAX
	int
	depends on HTTP_SERVER
	default 8

config JTAG
	bool "JTAG support"
	depends on $(dt_path_enabled,'/jtag')
	default y

config PERSISTENT_STORAGE
	bool "Persistent storage for config"
	default n
	# Enable Flash and Flash Map to access memory
	select FLASH
	select FLASH_MAP
	select FLASH_SHELL if SHELL
	# Writing internal flash that is used for XIP requires
	# that the flash driver is relocated into RAM.
	select CODE_DATA_RELOCATION_SRAM
	# XXX: May need to enable these, or disable IRQs in the flash
	# erase and program functions while flash is being written.
	# select SRAM_VECTOR_TABLE
	# select SRAM_SW_ISR_TABLE
	# select DEVICE_MUTABLE
	
	# Enable Filesystem and LittleFS
	select FILE_SYSTEM
	select FILE_SYSTEM_LITTLEFS
	select FILE_SYSTEM_MKFS

if JTAG

config JTAG_DAEMON_STACK_SIZE
	int "JTAG daemon stack size"
	default 1024

config JTAG_DAEMON_PRIORITY
	int "JTAG daemon priority"
	default 5

endif

source "Kconfig.zephyr"
